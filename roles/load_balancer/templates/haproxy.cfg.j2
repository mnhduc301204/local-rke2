global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin
    stats timeout 30s
    user haproxy
    group haproxy
    daemon
    maxconn 4096

defaults
    log global
    mode http
    option httplog
    option dontlognull
    timeout connect 5s
    timeout client  60s
    timeout server  60s

frontend k8s_ingress_http
    bind *:80
    mode http
    option forwardfor
    http-request set-header X-Forwarded-Proto http
    default_backend k8s_ingress_http_nodes

backend k8s_ingress_http_nodes
    mode http
    balance roundrobin
    option httpchk GET /
    default-server inter 5s fall 3 rise 2
{% for node in rke2_nodes %}
    server {{ node.name }} {{ node.ip }}:{{ ingress_http_nodeport }} check
{% endfor %}

frontend k8s_ingress_https
    bind *:443
    mode tcp
    option tcplog
    default_backend k8s_ingress_https_nodes

backend k8s_ingress_https_nodes
    mode tcp
    balance roundrobin
    default-server inter 5s fall 3 rise 2
{% for node in rke2_nodes %}
    server {{ node.name }} {{ node.ip }}:{{ ingress_https_nodeport }} check
{% endfor %}

listen stats
    bind *:8404
    mode http
    stats enable
    stats uri /stats
    stats refresh 10s
